rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidNavDoc(data) {
      return data.keys().hasAll(['date']) 
        && data.date is string 
        && data.date.size() == 10 
        && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    match /nav_history/{dateId} {
      allow read: if true; 
      allow create, update: if isValidNavDoc(request.resource.data);
      allow delete: if false; 
    }
  }
}
